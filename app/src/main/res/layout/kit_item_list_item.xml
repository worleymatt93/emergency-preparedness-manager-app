<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Medium">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="12dp"
        android:paddingTop="10dp"
        android:paddingEnd="12dp"
        android:paddingBottom="10dp">

        <!-- Row 1: Item name (left) -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/itemNameText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="?attr/colorOnSurface"
            android:text="@string/kit_item"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/qtySummary"
            app:layout_constraintHorizontal_bias="0"
            tools:text="Water" />

        <!-- Row 1: Qty summary (right): "Qty: 3" -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/qtySummary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:contentDescription="@string/quantity"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Qty: 3" />

        <!-- Row 2: Expiration (left) -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/itemMetaText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:text="@string/expiration_date"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/itemNameText"
            app:layout_constraintEnd_toStartOf="@+id/quantityControls"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:text="Expires: 03/01/2026" />

        <!-- Row 2: Quantity controls (right) -->
        <LinearLayout
            android:id="@+id/quantityControls"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/itemMetaText"
            app:layout_constraintBottom_toBottomOf="@+id/itemMetaText">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDecrement"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="@string/decrease_quantity"
                app:icon="@drawable/baseline_remove_24"
                app:iconTint="?attr/colorOnSurface"
                app:iconSize="20dp" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/quantityText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="10dp"
                android:textAppearance="?attr/textAppearanceTitleSmall"
                android:textColor="?attr/colorOnSurface"
                android:contentDescription="@string/quantity"
                tools:text="3" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnIncrement"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="@string/increase_quantity"
                app:icon="@drawable/baseline_add_24"
                app:iconTint="?attr/colorOnSurface"
                app:iconSize="20dp" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>